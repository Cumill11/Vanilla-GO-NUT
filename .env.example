# Port on which the app listens (default: 5000)
PORT=5000

# NUT Servers configuration (comma-separated, format: Name=host:port)
# The "Name=" prefix is optional; port defaults to 3493.
# The name is shown as the card title even when the UPS is offline.
NUT_SERVERS=UPS Mac=192.168.1.10:3493,UPS Server=192.168.1.11:3493

# Models for which "OL CHRG" status should be shown as "Online" instead of "Charging"
NUT_OL_CHRG_AS_ONLINE=VI2200SHL

# Dashboard refresh interval in seconds (default: 30)
REFRESH_INTERVAL=30
