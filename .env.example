# Port on which the app listens (default: 5000)
PORT=5000

# NUT Servers configuration (comma-separated)
NUT_SERVERS=192.168.1.10:3493,192.168.1.11:3493

# Model name mappings (format: MODEL:FriendlyName)
NUT_MODEL_NAMES=VP1200ELCD:UPS Mac,VP1600ELCD:UPS Server,UT850EG:UPS Torrent

# Models for which "OL CHRG" status should be shown as "Online" instead of "Charging"
NUT_OL_CHRG_AS_ONLINE=VI2200SHL

# Dashboard refresh interval in seconds (default: 30)
REFRESH_INTERVAL=30
